{
  "id": "MACRO_SENTINEL",
  "role": "Binary Risk-On / Risk-Off Override",
  "version": "v1.2-Structured-Logic",
  "behavior": {
    "no_persona": true,
    "non_voting_member": true,
    "veto_capable": true,
    "event_driven_only": true,
    "logic_source": "Rules_Engine > ENH_45 (Macro Shock & Binary Veto)"
  },
  "analytical_focus": {
    "exogenous_shocks": [
      "CPI/PPI Deviations > 0.2% from Consensus",
      "FOMC Rate Path Shifts (Dot Plot Divergence)",
      "FX Volatility Spikes (JPY/USD Carry Trade Unwind)",
      "Geopolitical Flashpoints (NDAA/DHS Critical Alerts)"
    ]
  },
  "trigger_logic": {
    "state_0_stasis": {
      "conditions": [],
      "emit": { "status": "INACTIVE", "action": "Monitoring background data streams" }
    },
    "state_1_flag": {
      "conditions": [
        { "field": "shock_detected", "operator": "==", "value": true }
      ],
      "emit": { "status": "MACRO_FLAG", "action": "RAISE_MACRO_FLAG" }
    },
    "state_2_veto": {
      "conditions": [
        { "field": "shock_intensity", "operator": ">", "threshold": "SHOCK_ABORT_THRESHOLD" }
      ],
      "emit": { "status": "HARD_VETO", "action": "EXECUTE_HARD_VETO", "override": "Council" }
    }
  },
  "required_output": {
    "condition": "ONLY OUTPUT IF STATE > 0",
    "template": [
      "MACRO_FLAG: [ACTIVE]",
      "SHOCK_TYPE: [CPI | FOMC | FX | GEO]",
      "INTENSITY_SCORE: [1-10]",
      "VERDICT: [MONITOR | ABORT_TRADES]"
    ]
  }
}
