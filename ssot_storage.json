{
  "role": "GEM SSoT Controller",
  "version": "v3.11-Sync-Guarded",
  "description": "Passive Data Schema and State Container. ALL EXECUTION LOGIC DEFERRED TO GEM_RULE_ENFORCER_ENGINE.",
  "knowledge_binding": {
    "source": "ATTACHED_KNOWLEDGE_BASE (SSOT_DOC - Attached 'rules' Google Doc)",
    "priority": "ABSOLUTE",
    "instruction": "You are the GUARDIAN of the SSoT. Your internal state MUST mirror the attached 'GEM_Context_SSoT' document exactly. Reject any internal drift."
  },
  "layer_model": {
    "immutable_background": [
      "mapping_rules",
      "risk_parameters",
      "persistence_contract",
      "historical_memory"
    ],
    "mutable_state": [
      "state_context",
      "portfolio_snapshot",
      "forensic_intelligence",
      "runtime_flags",
      "macro_calendar_shield"
    ]
  },
  "persistence_contract": {
    "protected_sections": [
      "forensic_intelligence",
      "risk_parameters",
      "mapping_rules"
    ],
    "merge_behavior": "PRESERVE_IF_NOT_UPDATED",
    "field_level_merge": {
      "strategy": "KEYWISE",
      "rule": "IF_KEY_ABSENT_IN_UPDATE_KEEP_OLD_VALUE"
    }
  },
  "update_protocol": {
    "mode": "FULL_STATE_OUTPUT",
    "instruction": "Output complete SSoT JSON. Increment 'sync_id' per update.",
    "logic_source": "RULES_DOC (Attached 'rules' Google Doc)",
    "coordination": "Accept 'Proposed State' Handshake from Context Engine. Reference RULES_DOC (Attached 'rules' Google Doc) > MANDATE_06 and MANDATE_13.",
    "mandate_source": "See terminal.json > shared_behavior > mandate_source",
    "allowed_update_targets": [
      "state_context",
      "portfolio_snapshot",
      "forensic_intelligence",
      "runtime_flags",
      "macro_calendar_shield"
    ]
  },
  "historical_memory": {
    "forensic_intelligence_archive": {
      "mode": "APPEND_ONLY",
      "max_entries": 500,
      "prune_rule": "LRU",
      "target_collection": "historical_facts"
    }
  },
  "deletion_rules": {
    "allow_deletion": false,
    "require_explicit_flag": "DELETE_FIELD",
    "calendar_shield_protection": {
      "scope": "macro_calendar_shield.active_events_window",
      "rule": "TEMPORAL_IMMUTABILITY",
      "instruction": "Events where event.date >= current_date are IMMUTABLE — cannot be deleted, overwritten, or omitted during merge. Only events where event.date < current_date may be pruned.",
      "enforcement": "MANDATORY — applies during merge_engine processing and APPLY_DELETION_RULES step",
      "violation_action": "REJECT_UPDATE and emit CALENDAR_SHIELD_INTEGRITY_VIOLATION to forensic_intelligence.risk_alerts"
    }
  },
  "context_echo": {
    "require_full_ingestion": true
  },
  "state_context": {
    "account_profile": "STRING",
    "risk_regime": "STRING",
    "alpha_sentry_mode": "STRING",
    "last_updated": "TIMESTAMP"
  },
  "forensic_intelligence": {
    "active_flags": [],
    "narrative_log": [],
    "drift_status": "STABLE",
    "risk_alerts": []
  },
  "portfolio_snapshot_update_schema": {
    "ticker_fields": {
      "trade_state": "STRING (LONG | NO_TRADE | EXIT)",
      "no_trade_reason": "STRING | NULL",
      "sizing_units": "FLOAT (ATR-Adjusted Quantity)"
    }
  },
  "portfolio_risk_geometry": {
    "avg_portfolio_corr": "FLOAT",
    "max_pairwise_corr": "FLOAT",
    "sector_exposure": "Reference RULES_DOC (Attached 'rules' Google Doc) > sector_taxonomy (Canonical)",
    "correlation_action": "STRING (MONITOR | REDUCE | NO_TRADE)"
  },
  "portfolio_snapshot": {
    "schema_reference": "RULES_DOC (Attached 'rules' Google Doc) > ENH_32 (Canonical Schema)",
    "defaults": {
      "social_velocity_z_score": 0.0,
      "sentiment_divergence_flag": false,
      "retail_crowding_status": "STABLE",
      "hard_catalyst": {
        "type": "NONE",
        "details": "N/A",
        "impact": "LOW"
      }
    }
  },
  "risk_parameters": {
    "SCHEMA_VERSION": "1.4.0-Merged-V7-Consensus",
    "GEX_POSTURE": "STRING",
    "SSR_STATUS": "BOOLEAN",
    "CONSENSUS_ACTIVE": true,
    "drift_control_threshold": "Reference RULES_DOC (Attached 'rules' Google Doc) > system_thresholds > DRIFT_CONTROL_THRESHOLD (Canonical)",
    "account_friction_settings": {
      "round_trip_cost_basis": "Reference RULES_DOC (Attached 'rules' Google Doc) > system_thresholds > ROUND_TRIP_COST_BASIS (Canonical)",
      "min_drawdown_threshold": "Reference RULES_DOC (Attached 'rules' Google Doc) > system_thresholds > ALPHA_FRICTION_MINIMUM (Canonical)",
      "tax_structure": "DEFERRED_WITHDRAWAL"
    }
  },
  "schema_name": "Keep_Sync_Protocol",
  "v": "3.10",
  "mapping_rules": {
    "title_template": "SSoT Backup - {timestamp} {risk_regime}",
    "text_content_structure": {
      "header": "Terminal Sync: {last_updated}",
      "risk_status": "Regime: {risk_regime}",
      "portfolio_summary": "Active Tickers: {ticker_list}",
      "forensic_flags": "Active Flags: {active_forensic_flags}",
      "consensus_summary": "Council Posture: {final_posture} (S_A Score: {agreement_score_sa})"
    },
    "markdown_content_logic": "WRAP_SSOT_FULL_DUMP_IN_CODE_BLOCK",
    "field_conversion": [
      {
        "internal": "ticker",
        "keep_display": "Asset"
      },
      {
        "internal": "shares",
        "keep_display": "Qty"
      },
      {
        "internal": "price",
        "keep_display": "Current"
      },
      {
        "internal": "status",
        "keep_display": "Rating"
      },
      {
        "internal": "agreement_score_sa",
        "keep_display": "Consensus_Score"
      }
    ]
  },
  "macro_calendar_shield": {
    "status": "STRING (CLEAR | PROXIMITY_ALERT | EVENT_DAY | BLACKOUT)",
    "next_event": {
      "type": "STRING (FOMC | CPI | PPI | NFP | GDP | PCE | RETAIL_SALES | ISM | JOBLESS_CLAIMS | EARNINGS_SEASON | OTHER)",
      "date": "DATE (YYYY-MM-DD)",
      "proximity_hours": "INT",
      "consensus_estimate": "STRING | NULL",
      "impact_tier": "STRING (TIER_1 | TIER_2 | TIER_3)"
    },
    "shield_posture": "STRING (FULL_RISK | REDUCED_RISK | DEFENSIVE | NO_NEW_ENTRIES)",
    "sizing_dampener": "FLOAT (0.25 - 1.0)",
    "active_events_window": "ARRAY<OBJECT> (Rolling 5-day forward calendar)"
  },
  "runtime_flags": {
    "sync_id": "STRING",
    "market_status": "STRING",
    "engine_mode": "STRING"
  }
}