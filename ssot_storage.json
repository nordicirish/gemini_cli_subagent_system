{
  "role": "GEM SSoT Controller",
  "version": "v3.2-Alpha-Friction-Patched",
  "description": "Passive Data Schema and State Container. ALL EXECUTION LOGIC DEFERRED TO RULES_ENGINE.",
  "layer_model": {
    "immutable_background": [
      "mapping_rules",
      "risk_parameters",
      "persistence_contract",
      "historical_memory"
    ],
    "mutable_state": [
      "state_context",
      "portfolio_snapshot",
      "forensic_intelligence",
      "runtime_flags"
    ]
  },
  "persistence_contract": {
    "protected_sections": [
      "forensic_intelligence",
      "risk_parameters",
      "mapping_rules"
    ],
    "merge_behavior": "PRESERVE_IF_NOT_UPDATED",
    "field_level_merge": {
      "strategy": "KEYWISE",
      "rule": "IF_KEY_ABSENT_IN_UPDATE_KEEP_OLD_VALUE"
    }
  },
  "update_protocol": {
    "mode": "FULL_STATE_OUTPUT",
    "instruction": "Output complete SSoT JSON. Increment 'sync_id' per update.",
    "allowed_update_targets": [
      "state_context",
      "portfolio_snapshot",
      "forensic_intelligence",
      "runtime_flags"
    ]
  },
  "historical_memory": {
    "forensic_intelligence_archive": {
      "mode": "APPEND_ONLY",
      "max_entries": 500,
      "prune_rule": "LRU",
      "target_collection": "historical_facts"
    }
  },
  "deletion_rules": {
    "allow_deletion": false,
    "require_explicit_flag": "DELETE_FIELD"
  },
  "context_echo": {
    "require_full_ingestion": true
  },
  "state_context": {
    "account_profile": "STRING",
    "risk_regime": "STRING",
    "alpha_sentry_mode": "STRING",
    "last_updated": "TIMESTAMP"
  },
  "forensic_intelligence": {
    "active_flags": [],
    "narrative_log": [],
    "drift_status": "STABLE",
    "risk_alerts": []
  },
  "portfolio_snapshot_update_schema": {
    "ticker_fields": {
      "trade_state": "STRING (LONG | NO_TRADE | EXIT)",
      "no_trade_reason": "STRING | NULL",
      "sizing_units": "FLOAT (ATR-Adjusted Quantity)"
    }
  },
  "portfolio_risk_geometry": {
    "avg_portfolio_corr": "FLOAT",
    "max_pairwise_corr": "FLOAT",
    "sector_exposure": {
      "defense_tech": "FLOAT (%)",
      "neuropsychiatry": "FLOAT (%)",
      "infrastructure": "FLOAT (%)"
    },
    "correlation_action": "STRING (MONITOR | REDUCE | NO_TRADE)"
  },
  "portfolio_snapshot": [
    {
      "ticker": "STRING",
      "shares": "INT",
      "wac": "FLOAT",
      "price": "FLOAT",
      "health_score": "FLOAT",
      "net_gex_total": "FLOAT",
      "dealer_posture": "STRING",
      "gex_exposure": "FLOAT",
      "ma_50": "FLOAT",
      "ma_200": "FLOAT",
      "gex_slope": "FLOAT",
      "gamma_flip_price": "FLOAT",
      "inventory_velocity_delta": "FLOAT",
      "status": "STRING",
      "social_velocity_z_score": 0.0,
      "sentiment_divergence_flag": false,
      "retail_crowding_status": "STABLE",
      "hard_catalyst": {
        "type": "NONE",
        "details": "N/A",
        "impact": "LOW"
      },
      "scrutiny_audit": {
        "agreement_score_sa": "FLOAT (e.g., 0.82)",
        "fatal_flaw_score": "INT (0-10)",
        "final_posture": "STRING (e.g., BULLISH_STABLE)",
        "derivation": {
          "bullish_component": "FLOAT (w*C*V)",
          "red_team_component": "FLOAT (w*C*V)",
          "structural_component": "FLOAT (w*C*V)"
        },
        "agent_votes": [
          {
            "agent": "BULLISH_ADVOCATE",
            "verdict": "STRING",
            "confidence": "FLOAT"
          },
          {
            "agent": "RED_TEAM_PESSIMIST",
            "verdict": "STRING",
            "confidence": "FLOAT"
          },
          {
            "agent": "NEUTRAL_STRUCTURALIST",
            "verdict": "STRING",
            "confidence": "FLOAT"
          }
        ]
      }
    }
  ],
  "risk_parameters": {
    "SCHEMA_VERSION": "1.4.0-Merged-V7-Consensus",
    "GEX_POSTURE": "STRING",
    "SSR_STATUS": "BOOLEAN",
    "CONSENSUS_ACTIVE": true,
    "drift_control_threshold": 0.005,
    "account_friction_settings": {
      "round_trip_cost_basis": 0.01,
      "min_drawdown_threshold": 0.025,
      "tax_structure": "DEFERRED_WITHDRAWAL"
    }
  },
  "schema_name": "Keep_Sync_Protocol",
  "v": "3.10",
  "mapping_rules": {
    "title_template": "SSoT Backup - {timestamp} {risk_regime}",
    "text_content_structure": {
      "header": "Terminal Sync: {last_updated}",
      "risk_status": "Regime: {risk_regime}",
      "portfolio_summary": "Active Tickers: {ticker_list}",
      "forensic_flags": "Active Flags: {active_forensic_flags}",
      "consensus_summary": "Council Posture: {final_posture} (S_A Score: {agreement_score_sa})"
    },
    "markdown_content_logic": "WRAP_SSOT_FULL_DUMP_IN_CODE_BLOCK",
    "field_conversion": [
      {
        "internal": "ticker",
        "keep_display": "Asset"
      },
      {
        "internal": "shares",
        "keep_display": "Qty"
      },
      {
        "internal": "price",
        "keep_display": "Current"
      },
      {
        "internal": "status",
        "keep_display": "Rating"
      },
      {
        "internal": "agreement_score_sa",
        "keep_display": "Consensus_Score"
      }
    ]
  },
  "runtime_flags": {
    "sync_id": "STRING",
    "market_status": "STRING",
    "engine_mode": "STRING"
  }
}